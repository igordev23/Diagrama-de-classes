    <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;classDiagram\n    class Pessoa {\n        &lt;&lt;abstract&gt;&gt;\n        +UUID id\n        +String nome\n        +String email\n        +bool ativo\n    }\n    class Usuario {\n        +PerfilEnum perfil\n        +DateTime ultimoLogin\n        +Time horarioPermitidoInicio\n        +Time horarioPermitidoFim\n        +autenticar(email, senha) bool\n        +emitirCertificado(participante, template) Certificado\n    }\n    class Participante {\n        +String cpf\n        +Date dataCadastro\n        +vincularCurso(curso) void\n    }\n    class Organizacao {\n        +String nome\n        +String cnpj\n        +bool ativo\n        +adicionarMembro(usuario) void\n    }\n    class Curso {\n        +String nome\n        +int cargaHoraria\n        +String descricao\n        +inscreverParticipante(participante) void\n    }\n    class Matricula {\n        +Date dataVinculo\n        +StatusMatriculaEnum status\n    }\n    class UsuarioOrganizacao {\n        +PerfilEnum perfil\n    }\n    class Template {\n        +String nome\n        +bool ativo\n    }\n    class TemplateVersao {\n        +String versao\n        +String arquivoPath\n        +DateTime criadoEm\n    }\n    class CampoDinamico {\n        +String nomeCampo\n        +String marcador\n        +String tipo\n    }\n    class AssinaturaDigital {\n        +String imagemAssinatura\n        +String hashVerificacao\n        +DateTime dataRegistro\n    }\n    class Certificado {\n        +String codigoUnico\n        +DateTime dataEmissao\n        +String localEmissao\n        +StatusCertificadoEnum status\n        +String arquivoPDF\n        +String qrCode\n        +gerarPDF() void\n        +assinar(assinatura) void\n        +enviarEmail(envio) void\n    }\n    class CertificadoCampo {\n        +String nome\n        +String valor\n    }\n    class EnvioEmail {\n        +String destinatario\n        +StatusEnvioEnum status\n        +int tentativas\n        +DateTime dataEnvio\n        +String mensagemPersonalizada\n        +enviar() bool\n    }\n    class Log {\n        +String tipo\n        +String descricao\n        +DateTime dataHora\n        +String ip\n    }\n    class LogAuditoria {\n        +String acao\n        +DateTime dataHora\n        +String local\n        +registrar(usuario) void\n    }\n    class Sessao {\n        +String tokenHash\n        +String ipAddress\n        +bool ativo\n    }\n    class FilaProcessamento {\n        +String tipoAcao\n        +StatusFilaEnum status\n        +int prioridade\n        +DateTime criadoEm\n    }\n    class Importacao {\n        +String nomeArquivo\n        +StatusImportacaoEnum status\n    }\n    class ChamadoSuporte {\n        +String titulo\n        +String descricao\n        +DateTime dataAbertura\n        +StatusChamadoEnum status\n        +DateTime dataFechamento\n        +abrir(usuario) void\n        +fechar() void\n    }\n    class ConfiguracaoSistema {\n        +bool envioAutomatico\n        +String regraReemissao\n        +int maximoReemissoes\n        +String mensagemPadraoEmail\n        +String termosUso\n        +bool sistemaOnline\n        +aplicar() void\n    }\n\n    Pessoa &lt;|-- Usuario\n    Pessoa &lt;|-- Participante\n    Organizacao \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Usuario : UsuarioOrganizacao\n    Organizacao \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Participante\n    Organizacao \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Curso\n    Organizacao \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Template\n    Organizacao \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Certificado\n    Organizacao \&quot;1\&quot; --&gt; \&quot;1\&quot; ConfiguracaoSistema\n    Organizacao \&quot;1\&quot; --&gt; \&quot;0..*\&quot; ChamadoSuporte\n    Organizacao \&quot;1\&quot; --&gt; \&quot;0..*\&quot; FilaProcessamento\n    Organizacao \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Importacao\n    Participante \&quot;0..*\&quot; --&gt; \&quot;0..*\&quot; Curso : Matricula\n    Usuario \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Log\n    Usuario \&quot;1\&quot; --&gt; \&quot;0..*\&quot; LogAuditoria\n    Usuario \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Sessao\n    Usuario \&quot;1\&quot; --&gt; \&quot;0..*\&quot; ChamadoSuporte : abriu\n    Usuario \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Certificado : emitiu\n    Template \&quot;1\&quot; --&gt; \&quot;0..*\&quot; TemplateVersao\n    Template \&quot;1\&quot; *-- \&quot;0..*\&quot; CampoDinamico\n    Template \&quot;1\&quot; --&gt; \&quot;0..1\&quot; AssinaturaDigital\n    Certificado \&quot;1\&quot; --&gt; \&quot;1\&quot; Template\n    Certificado \&quot;1\&quot; --&gt; \&quot;0..1\&quot; EnvioEmail\n    Certificado \&quot;1\&quot; *-- \&quot;0..*\&quot; CertificadoCampo\n    Certificado \&quot;1\&quot; --&gt; \&quot;1\&quot; AssinaturaDigital : assinadoCom&quot;,&#xa;  &quot;config&quot;: {&#xa;    &quot;theme&quot;: &quot;neutral&quot;,&#xa;    &quot;arrowMarkerAbsolute&quot;: false,&#xa;    &quot;flowchart&quot;: {&quot;htmlLabels&quot;: false},&#xa;    &quot;sequence&quot;: {&#xa;      &quot;diagramMarginX&quot;: 50, &quot;diagramMarginY&quot;: 10, &quot;actorMargin&quot;: 50,&#xa;      &quot;width&quot;: 150, &quot;height&quot;: 65, &quot;boxMargin&quot;: 10, &quot;boxTextMargin&quot;: 5,&#xa;      &quot;noteMargin&quot;: 10, &quot;messageMargin&quot;: 35, &quot;mirrorActors&quot;: true,&#xa;      &quot;bottomMarginAdj&quot;: 1, &quot;useMaxWidth&quot;: true, &quot;rightAngles&quot;: false,&#xa;      &quot;showSequenceNumbers&quot;: false&#xa;    },&#xa;    &quot;gantt&quot;: {&#xa;      &quot;titleTopMargin&quot;: 25, &quot;barHeight&quot;: 20, &quot;barGap&quot;: 4, &quot;topPadding&quot;: 50,&#xa;      &quot;leftPadding&quot;: 75, &quot;gridLineStartPadding&quot;: 35, &quot;fontSize&quot;: 11,&#xa;      &quot;fontFamily&quot;: &quot;\&quot;Open-Sans\&quot;, \&quot;sans-serif\&quot;&quot;, &quot;numberSectionStyles&quot;: 4,&#xa;      &quot;axisFormat&quot;: &quot;%Y-%m-%d&quot;&#xa;    }&#xa;  }&#xa;}">
      <mxCell style="shape=image;noLabel=1;verticalAlign=top;imageAspect=1;" vertex="1" parent="1">
        <mxGeometry x="40" width="580" height="660" as="geometry" />
      </mxCell>
